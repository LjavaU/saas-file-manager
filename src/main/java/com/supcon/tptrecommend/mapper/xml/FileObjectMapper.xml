<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.supcon.tptrecommend.mapper.FileObjectMapper">
    <!--
       一般情况下，尽可能使用 Mapper 进行 CRUD 增删改查即可。
       无法满足的场景，例如说多表关联查询，才使用 XML 编写 SQL。
    -->

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.supcon.tptrecommend.entity.FileObject">
        <result column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="user_id" property="userId"/>
        <result column="user_name" property="userName"/>
        <result column="object_name" property="objectName"/>
        <result column="original_name" property="originalName"/>
        <result column="bucket_name" property="bucketName"/>
        <result column="content_type" property="contentType"/>
        <result column="file_size" property="fileSize"/>
        <result column="tags" property="tags"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id
        ,
            tenant_id,
            create_time,
            update_time,
        user_id, user_name, object_name, original_name, bucket_name, content_type, file_size, tags
    </sql>

    <update id="updateFileAttributes">
        UPDATE file_object
        <set>
            <if test="req.subCategory != null and req.subCategory != ''">
                sub_category = #{req.subCategory},
            </if>
            <if test="req.thirdLevelCategory != null and req.thirdLevelCategory != ''">
                third_level_category = #{req.thirdLevelCategory},
            </if>
            <if test="req.ability != null and req.ability != ''">
                ability = #{req.ability},
            </if>
            update_time = NOW()
        </set>
        WHERE object_name = #{req.objectName}
    </update>
</mapper>
